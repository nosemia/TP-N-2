#include <iostream>
#include <vector>
using namespace std;

int main() {

    vector<int> v1 = {1,3,5,7};
    vector<int> v2 = {2,4,6,8};

    vector<int> fusion;

    int i = 0;
    int j = 0;

    while(i < v1.size() && j < v2.size()) {

        if(v1[i] < v2[j]) {

            fusion.push_back(v1[i]);
            i++;
        }
        else {

            fusion.push_back(v2[j]);
            j++;
        }
    }

    while(i < v1.size()) {

        fusion.push_back(v1[i]);
        i++;
    }

    while(j < v2.size()) {

        fusion.push_back(v2[j]);
        j++;
    }

    cout << "Vector fusionado:";

    for(int n : fusion) {
        cout << n << " ";
    }

    return 0;
}
