#include <iostream>
#include <vector>
using namespace std;

int main() {

    vector<int> numeros = {1,2,3,4,5,6,7,8};

    int cambio;

    for(int i = 0; i < numeros.size() / 2; i++) {

        cambio = numeros[i];
        numeros[i] = numeros[numeros.size() - 1 - i];
        numeros[numeros.size() - 1 - i] = cambio;
    }

    cout << "Vector invertido:";

    for(int n : numeros) {

        cout << n << " ";
    }

    return 0;
}
